# 가상환경 폴더 (가장 중요)
venv/
env/
.venv/
healthModel/model/
healthModel/healthModel/
.claude
# 파이썬 캐시
__pycache__/
*.pyc

# 환경변수
.env

# (추후 모델 파일)
models/
*.pkl
*.joblib
# Ignore all markdown files everywhere in the project
**/*.md
*.md

# Ignore Python virtual environment/Conda directories inside healthModel/healthModel
healthModel/healthModel/conda-meta/
healthModel/healthModel/DLLs/
healthModel/healthModel/etc/
healthModel/healthModel/include/
healthModel/healthModel/Lib/
healthModel/healthModel/Library/
healthModel/healthModel/libs/
healthModel/healthModel/Scripts/
healthModel/healthModel/share/
healthModel/healthModel/Tools/

# Ensure requirements.txt in the first folder is tracked
!healthModel/requirements.txt

# Ignore compiled DLL/DILL library binary files
**/*.dll
**/*.dill
*.dll
*.dill

# Ignore Python interpreter files in healthModel/healthModel
healthModel/healthModel/python*
healthModel/healthModel/*.pdb
healthModel/healthModel/.nonadmin
healthModel/healthModel/LICENSE_PYTHON.txt

# Claude 하네스 (개인용 - 팀 공유 안 함)
# 참고: 위 **/*.md 규칙으로 CLAUDE.md 류는 이미 제외되지만, .claude 디렉토리 전체를 명시적으로 제외
.claude/
CLAUDE.md
**/CLAUDE.md

# VS Code workspace settings
.vscode/